# Telegram
BOT_TOKEN=123456:ABCDEF
TELEGRAM_SECRET_TOKEN=supersecret

# Webhook targets
# Use ONE of the following:
# - TARGET_WEBHOOK_URL (single target)
# - TARGET_WEBHOOK_URLS (multi-target fan-out)

TARGET_WEBHOOK_URL=https://example.com/webhook
# TARGET_WEBHOOK_URLS=https://example.com/a,https://example.com/b

# Access control
PUBLIC_MODE=false
AUTHORIZED_CHAT_IDS=123456789

# Rate limiting & payload
RATE_LIMIT_PER_MIN=30
MAX_BODY_SIZE_KB=512

# Queue
QUEUE_BACKEND=sqlite
SQLITE_PATH=./events.db

# Optional defaults for /api/send and /api/pull
# If request omits chat_id/key, gateway falls back to these values.
DEFAULT_CHAT_ID=
DEFAULT_BOT_KEY=
# BOT_TOKEN_BY_KEY=primary:123456:AAA,secondary:654321:BBB
# DEFAULT_CHAT_ID_BY_KEY=primary:111111111,secondary:222222222

# Retry
MAX_RETRIES=5
BASE_RETRY_DELAY_SEC=2

# Pull API auth token (also used by /api/send)
PULL_API_TOKEN=change_me

# Outbound webhook signature (optional)
OUTBOUND_SECRET=